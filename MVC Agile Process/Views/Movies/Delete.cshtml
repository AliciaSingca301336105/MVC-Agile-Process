@model MVC_Agile_Process.Models.Movie

@{
    ViewData["Title"] = "Delete Movie";
}

<h1>Delete Movie</h1>

<h4>Are you sure you want to delete this movie?</h4>
<hr />

<div>
    <h4>Movie</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>Title</dt>
        <dd>@Model.Title</dd>
        <dt>Genre</dt>
        <dd>@Model.Genre</dd>
        <dt>Release Date</dt>
        <dd>@Model.ReleaseDate.ToShortDateString()</dd>
        <dt>Price</dt>
        <dd>@Model.Price</dd>
    </dl>
</div>

<form method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a href="@Url.Action("Index")" class="btn btn-default">Cancel</a>
</form>
